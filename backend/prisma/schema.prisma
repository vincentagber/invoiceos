generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String     @id @default(cuid())
  email         String     @unique
  password      String
  name          String?
  profilePicture String?   // URL to object storage (was Bytes)
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  deletedAt     DateTime?
  businesses    Business[]
}

model Business {
  id              String           @id @default(cuid())
  name            String
  ownerId         String
  owner           User             @relation(fields: [ownerId], references: [id])

  address         String?
  phone           String?
  email           String?
  taxNumber       String?
  paymentDetails  String?

  logo            String?          // URL to object storage (was Bytes)
  favicon         String?          // URL to object storage (was Bytes)
  icon            String?          // URL to object storage (was Bytes)
  brandColor      String?          @default("#4F46E5")
  customDomain    String?          @unique

  defaultCurrency   String?        @default("NGN")
  invoicePrefix     String?        @default("INV")
  defaultDuePeriod  String?        @default("Net 30 Days")
  defaultDiscount   Decimal?        @default(0) @db.Decimal(12, 2)
  defaultNotes      String?

  invoiceReminders  Boolean?       @default(false)
  documentStyle     String?        @default("Professional")
  estimatePrefix    String?        @default("EST")
  bccEmails         Boolean?       @default(false)

  autoSendInvoice   Boolean?       @default(false)
  paymentReminders  Boolean?       @default(true)
  dailySummary      Boolean?       @default(false)

  smtpConfig        Json?

  clients         Client[]
  invoices        Invoice[]
  templates       InvoiceTemplate[]
  automationRules AutomationRule[]
  quotations      Quotation[]
  subscription    Subscription?
  expenses        Expense[]

  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  deletedAt       DateTime?
  version         Int              @default(1)

  @@index([ownerId])
}

model Subscription {
  id              String      @id @default(cuid())
  businessId      String      @unique
  business        Business    @relation(fields: [businessId], references: [id], onDelete: Cascade)
  plan            String
  status          String
  amount          Decimal     @db.Decimal(12, 2)
  currency        String      @default("NGN")
  billingCycle    String
  startDate       DateTime    @default(now())
  endDate         DateTime
  paystackRef     String?     @unique

  createdAt       DateTime    @default(now())
  updatedAt       DateTime   @updatedAt
  transactions    SubscriptionTransaction[]
}

model SubscriptionTransaction {
  id              String      @id @default(cuid())
  subscriptionId  String
  subscription    Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  plan            String
  amount          Decimal     @db.Decimal(12, 2)
  billingCycle    String
  paystackRef     String?     @unique
  status          String
  createdAt       DateTime    @default(now())
  updatedAt       DateTime   @updatedAt
}

model Client {
  id          String    @id @default(cuid())
  businessId  String
  business    Business  @relation(fields: [businessId], references: [id], onDelete: Cascade)
  name        String
  contactName String?
  email       String
  address     String?
  phone       String?
  taxId       String?
  invoices    Invoice[]
  quotations  Quotation[]

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?
  version     Int       @default(1)

  @@unique([businessId, email])
  @@index([businessId])
}

model Invoice {
  id              String        @id @default(cuid())
  invoiceNumber   String
  businessId      String
  business        Business      @relation(fields: [businessId], references: [id], onDelete: Cascade)
  clientId        String
  client          Client        @relation(fields: [clientId], references: [id])

  status          InvoiceStatus @default(DRAFT)
  currency        String        @default("USD")
  issueDate       DateTime      @default(now())
  dueDate         DateTime

  items           InvoiceItem[]
  taxRate         Decimal       @default(0) @db.Decimal(5, 2)
  discountAmount  Decimal       @default(0) @db.Decimal(12, 2)
  totalAmount     Decimal       @db.Decimal(12, 2)

  viewCount       Int           @default(0)
  lastViewedAt    DateTime?

  isRecurring     Boolean       @default(false)
  recurringFrequency String?    // daily, weekly, monthly, custom

  payments        Payment[]

  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  deletedAt       DateTime?
  version         Int           @default(1)

  @@unique([businessId, invoiceNumber])
  @@index([businessId, status])
  @@index([clientId])
  @@index([dueDate])
}

model InvoiceItem {
  id          String   @id @default(cuid())
  invoiceId   String
  invoice     Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  description String
  quantity    Float
  unitPrice   Decimal  @db.Decimal(12, 2)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Quotation {
  id              String          @id @default(cuid())
  quotationNumber String
  businessId      String
  business        Business        @relation(fields: [businessId], references: [id], onDelete: Cascade)
  clientId        String
  client          Client          @relation(fields: [clientId], references: [id])

  status          QuotationStatus @default(DRAFT)
  currency        String          @default("USD")
  issueDate       DateTime        @default(now())
  expiryDate      DateTime

  items           QuotationItem[]
  taxRate         Decimal         @default(0) @db.Decimal(5, 2)
  discountAmount  Decimal         @default(0) @db.Decimal(12, 2)
  totalAmount     Decimal         @db.Decimal(12, 2)

  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  deletedAt       DateTime?
  version         Int             @default(1)

  @@unique([businessId, quotationNumber])
  @@index([businessId, status])
  @@index([clientId])
}

model QuotationItem {
  id          String    @id @default(cuid())
  quotationId String
  quotation   Quotation @relation(fields: [quotationId], references: [id], onDelete: Cascade)
  description String
  quantity    Float
  unitPrice   Decimal   @db.Decimal(12, 2)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Payment {
  id            String        @id @default(cuid())
  invoiceId     String
  invoice       Invoice       @relation(fields: [invoiceId], references: [id])
  amount        Decimal       @db.Decimal(12, 2)
  method        PaymentMethod
  status        PaymentStatus @default(PENDING)
  transactionId String?
  paidAt        DateTime?

  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([invoiceId])
  @@index([status])
}

model InvoiceTemplate {
  id         String   @id @default(cuid())
  businessId String
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  name       String
  config     Json

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model AutomationRule {
  id         String   @id @default(cuid())
  businessId String
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  trigger    String
  action     String
  delayDays  Int      @default(0)
  isActive   Boolean  @default(true)

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Expense {
  id           String   @id @default(cuid())
  businessId   String
  business     Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  userId       String?
  amount       Decimal  @db.Decimal(12, 2)
  category     String?
  description  String?
  date         DateTime @default(now())
  notes        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  deletedAt    DateTime?

  @@index([businessId, date])
  @@index([category])
}

enum InvoiceStatus {
  DRAFT
  SENT
  VIEWED
  PARTIAL
  PAID
  OVERDUE
  CANCELLED
}

enum QuotationStatus {
  DRAFT
  SENT
  VIEWED
  ACCEPTED
  REJECTED
  EXPIRED
}

enum PaymentMethod {
  CARD
  BANK_TRANSFER
  CRYPTO
  OTHER
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
  DISPUTED
  REFUNDED
  CHARGED_BACK
}
