# Supabase Configuration
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Database
DATABASE_URL=postgresql://user:password@your-project.supabase.co:5432/postgres?sslmode=require

# Authentication & Security
JWT_SECRET=change-this-to-a-random-64-char-hex-string
REFRESH_TOKEN_SECRET=change-this-to-another-random-64-char-hex-string
JWT_EXPIRY=24h

# App Configuration
PORT=4000
NODE_ENV=development
LOG_LEVEL=debug

# Frontend URLs
FRONTEND_URL=http://localhost:3000
FRONTEND_URL_DEV=http://localhost:3000

# External APIs
OPENAI_API_KEY=your-openai-key
PAYSTACK_SECRET_KEY=your-paystack-secret-key

# Email (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM_EMAIL=noreply@invoiceos.com
SMTP_FROM_NAME=InvoiceOS

# Error Tracking
SENTRY_DSN=https://key@sentry.io/project-id
