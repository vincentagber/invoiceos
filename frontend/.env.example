# Backend Configuration
# Set this to true to use the Node.js backend
NEXT_PUBLIC_USE_NODE=true

# Node.js API URL (Production)
NEXT_PUBLIC_NODE_API_URL=https://your-backend-api.com/api

# PHP API URL (Legacy/Alternative)
NEXT_PUBLIC_API_URL=https://your-legacy-api.com/backend/api

# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=your-supabase-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
