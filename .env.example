# ========================================
# Backend Environment Variables (Render)
# ========================================

# Database (Supabase PostgreSQL)
# Generate connection string from Supabase Dashboard → Settings → Database
DATABASE_URL=postgresql://postgres:PASSWORD@PROJECT.supabase.co:5432/postgres?sslmode=require

# Authentication & Security
# Generate with: openssl rand -hex 32
JWT_SECRET=your_very_long_random_secret_min_32_chars
JWT_EXPIRY=24h
REFRESH_TOKEN_SECRET=another_strong_secret_min_32_chars

# Supabase Configuration
# Get from Supabase Dashboard → Settings → API
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_KEY=your_service_key_here

# SMTP Configuration (Email notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your_app_specific_password
SMTP_FROM_EMAIL=noreply@invoiceos.com
SMTP_FROM_NAME=InvoiceOS

# Frontend URLs (for CORS & redirects)
FRONTEND_URL=https://invoiceos.com
FRONTEND_URL_DEV=http://localhost:3000

# External API Keys
OPENAI_API_KEY=sk-...
PAYSTACK_SECRET_KEY=sk_...

# Application
NODE_ENV=production
PORT=4000
LOG_LEVEL=info

# Error Tracking (Optional but recommended)
SENTRY_DSN=https://xxxx@sentry.io/xxxx

# ========================================
# Frontend Environment Variables (Vercel)
# ========================================

# These must be prefixed with NEXT_PUBLIC_ to be available in browser
NEXT_PUBLIC_USE_NODE=true
NEXT_PUBLIC_NODE_API_URL=https://invoiceos-api.render.com/api
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here

# Error tracking (Optional)
NEXT_PUBLIC_SENTRY_DSN=https://xxxx@sentry.io/xxxx
