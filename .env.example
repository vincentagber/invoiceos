# ========================================
# Backend Environment Variables (Render)
# ========================================

# Database (Supabase PostgreSQL)
DATABASE_URL=postgresql://postgres:PASSWORD@PROJECT.supabase.co:5432/postgres?sslmode=require

# Authentication & Security
# Generate with: openssl rand -hex 32
JWT_SECRET=your_very_long_random_secret_min_32_chars
JWT_EXPIRY=24h
REFRESH_TOKEN_SECRET=another_strong_secret_min_32_chars
ENCRYPTION_KEY=another_secret_for_smtp_encryption_min_32_chars

# Supabase Configuration (Optional — falls back to local JWT if not set)
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# SMTP Configuration (Email notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your_app_specific_password
SMTP_FROM_EMAIL=noreply@invoiceos.com
SMTP_FROM_NAME=InvoiceOS

# Payment Providers
PAYSTACK_SECRET_KEY=sk_live_...
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=pk_live_...
STRIPE_SECRET_KEY=sk_live_...         # Optional — enable when Stripe is integrated
STRIPE_WEBHOOK_SECRET=whsec_...       # Optional

# Frontend URLs (for CORS & redirects)
FRONTEND_URL=http://localhost:3000
FRONTEND_URL_DEV=http://localhost:3000

# External API Keys
OPENAI_API_KEY=sk-...

# Redis (Background Jobs & Queues)
REDIS_URL=redis://localhost:6379

# Application
NODE_ENV=production
PORT=4000
LOG_LEVEL=info

# Error Tracking (Optional but recommended)
SENTRY_DSN=https://xxxx@sentry.io/xxxx

# ========================================
# Frontend Environment Variables (Vercel)
# ========================================

NEXT_PUBLIC_REDIS_URL=redis://localhost:6379
NEXT_PUBLIC_USE_NODE=true
NEXT_PUBLIC_NODE_API_URL=http://localhost:4000/api
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=pk_test_...
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
NEXT_PUBLIC_SENTRY_DSN=https://xxxx@sentry.io/xxxx
